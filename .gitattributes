# Auto-normalize line endings: stored as LF in the repo, checked out as the
# platform default on each machine. Prevents whitespace-only "ghost diffs"
# when the project is edited across Windows / macOS / Linux / WSL.
* text=auto eol=lf

# Source & text assets — enforce LF explicitly
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.svg       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary assets — never normalize, never diff as text
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.zip       binary
*.docx      binary
*.xlsx      binary
*.pptx      binary
